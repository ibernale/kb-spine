{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kb-spine/schemas/entity.schema.json",
  "title": "Entity note (person / org / lab / model / product)",
  "description": "Frontmatter contract for hand-written entity notes under entities/.",
  "type": "object",
  "required": ["type", "subtype", "name", "slug", "tags", "status"],
  "additionalProperties": true,
  "properties": {
    "type": { "const": "entity" },
    "subtype": {
      "type": "string",
      "enum": ["person", "org", "lab", "model", "product"]
    },
    "name": { "type": "string", "minLength": 1 },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "aliases": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "status": {
      "type": "string",
      "enum": ["evergreen", "draft", "review", "archived"]
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 2,
      "description": "Must contain at least one type/* and one access/* tag."
    },
    "primary_writing": { "type": "string" },
    "x_handle": { "type": "string" },
    "github": { "type": "string" },
    "domain": { "type": "string" },
    "country": { "type": "string" },
    "tier": { "type": "integer", "minimum": 1, "maximum": 7 },
    "affiliations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "producer": { "type": "string" },
    "modality": {
      "type": "array",
      "items": { "type": "string", "enum": ["text", "image", "audio", "video", "code", "embedding"] }
    },
    "released": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "context_window": { "type": "integer", "minimum": 0 },
    "type_of": { "type": "string" }
  }
}
