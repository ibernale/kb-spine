{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kb-spine/schemas/note.schema.json",
  "title": "Ingested item note (paper / blog / report)",
  "description": "Frontmatter contract for items written by run_ingest.py — papers, blog posts, reports.",
  "type": "object",
  "required": ["title", "url", "source", "type", "authors", "published", "ingested", "tags"],
  "additionalProperties": true,
  "properties": {
    "title": { "type": "string", "minLength": 1 },
    "url": {
      "type": "string",
      "pattern": "^https?://"
    },
    "source": {
      "type": "string",
      "enum": [
        "arxiv", "anthropic", "openai", "deepmind", "meta", "mistral", "xai",
        "cohere", "microsoft", "nvidia", "apple", "ai2", "google",
        "deepseek", "alibaba", "qwen", "baichuan", "moonshot", "zhipu", "01ai",
        "stanford-hai", "mit-csail", "bair", "cmu", "princeton", "oxford",
        "nyu", "uw", "cambridge", "ethz", "epfl", "mila", "kaist", "tsinghua",
        "huggingface", "substack", "mckinsey", "bcg", "deloitte", "kpmg", "pwc", "ey", "wef",
        "eba", "ecb", "esma", "eiopa", "aepd", "bde", "cnmv",
        "eu-commission", "eu-ai-office", "edpb", "edps", "enisa", "esrb", "srb",
        "bafin", "acpr", "amf", "dnb", "afm", "boe-pra", "fca",
        "banca-italia", "consob", "finma", "snb",
        "cbi", "cssf", "bdp", "nbb", "fi-se", "knf", "mfsa",
        "bis", "fsb", "fatf", "nist", "iosco", "oecd", "imf", "world-bank",
        "cpmi", "iais", "ifrs",
        "ncsc-uk", "bsi-de", "anssi", "ccn-cert", "cisa",
        "bruegel", "ceps", "atlantic-council", "brookings", "chatham-house", "ecfr", "eui",
        "lawfare", "ai-now", "cset", "fpf", "cais", "govai", "carnegie", "rand",
        "ao-shearman", "linklaters", "hogan-lovells", "clifford-chance",
        "latham", "skadden", "gibson-dunn", "white-case", "cuatrecasas", "garrigues",
        "ft", "reuters", "politico-eu", "risk-net", "compliance-week", "gbrr",
        "langchain", "ietf", "owasp",
        "other"
      ]
    },
    "type": {
      "type": "string",
      "enum": ["paper", "blog-post", "report"]
    },
    "authors": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "published": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "ingested": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    }
  }
}
